// ─────────────────────────────────────────────────────────────────────────────
// OldTrailBikes Sri Lanka — Prisma schema
//
// Fully normalized PostgreSQL schema for:
//   • User accounts (customer / shop / admin) with bilingual preference
//   • Workshop diagnostic & booking engine
//   • Lifetime per-bike service history (keyed on registration plate)
//   • Peer-to-peer dirt bike marketplace
//   • Mechanic verified trust system (DB-trigger enforced)
//   • Multi-vendor parts store with per-line locked commissions
//   • Unified rating ecosystem (appointments OR parts, never both)
//
// All UUIDs are generated by the pgcrypto extension. Two custom triggers
// (touch_updated_at, set_mechanic_verified) and the review XOR check are
// added in the companion SQL migration `prisma/migrations/000_init_extensions_triggers/migration.sql`.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  SHOP
  ADMIN
}

enum Language {
  SI
  EN
}

enum IssueCategory {
  ENGINE_2_STROKE_REBUILD
  ENGINE_4_STROKE_REBUILD
  SUSPENSION_TUNING
  BRAKE_REPAIR
  ELECTRICAL_FAULT
  DRIVE_ISSUE
  TYRE_WORK
  OTHER
}

enum AppointmentStatus {
  PENDING
  INSPECTED
  WAITING_FOR_PARTS
  REPAIRED
}

enum EngineType {
  TWO_STROKE
  FOUR_STROKE
  ELECTRIC
}

enum ListingStatus {
  AVAILABLE
  PENDING
  SOLD
}

enum ShopStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  FULFILLED
  CANCELLED
}

enum ReviewTargetType {
  APPOINTMENT
  PART
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String    @unique
  passwordHash      String    @map("password_hash")
  fullName          String    @map("full_name")
  phone             String?
  preferredLanguage Language  @default(EN) @map("preferred_language")
  role              UserRole  @default(CUSTOMER)
  isActive          Boolean   @default(true) @map("is_active")
  emailVerifiedAt   DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Workshop side
  appointments        Appointment[]            @relation("CustomerAppointments")
  ownedServiceBikes   ServiceBike[]            @relation("OwnedServiceBikes")
  verificationsIssued MechanicVerification[]   @relation("AdminVerifications")
  shopApprovalsGiven  Shop[]                   @relation("AdminApprovedShops")

  // Marketplace side
  listings BikeForSale[] @relation("SellerListings")

  // Shop side (a user with role=SHOP owns at most one Shop)
  shop Shop? @relation("ShopOwner")

  // Commerce
  orders  Order[]  @relation("CustomerOrders")
  reviews Review[] @relation("AuthorReviews")

  @@index([role])
  @@map("users")
}

// ─── BRANDS (normalized) ─────────────────────────────────────────────────────

model Brand {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  listings     BikeForSale[]
  parts        SparePart[]
  serviceBikes ServiceBike[]

  @@map("brands")
}

// ─── SERVICE BIKES (registry of physical bikes for lifetime repair history) ──

model ServiceBike {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  registrationPlate String      @unique @map("registration_plate")
  brandId           String?     @map("brand_id") @db.Uuid
  model             String?
  year              Int?
  engineType        EngineType? @map("engine_type")
  ownerUserId       String?     @map("owner_user_id") @db.Uuid
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  brand        Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  owner        User?         @relation("OwnedServiceBikes", fields: [ownerUserId], references: [id], onDelete: SetNull)
  appointments Appointment[]

  @@index([ownerUserId])
  @@index([brandId])
  @@map("service_bikes")
}

// ─── APPOINTMENTS ────────────────────────────────────────────────────────────

model Appointment {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId            String            @map("customer_id") @db.Uuid
  serviceBikeId         String            @map("service_bike_id") @db.Uuid
  issueCategory         IssueCategory     @map("issue_category")
  customerMessage       String?           @map("customer_message")
  preInspectionPhotos   String[]          @default([]) @map("pre_inspection_photos")
  contactPhone          String            @map("contact_phone")
  preferredDate         DateTime          @map("preferred_date") @db.Timestamptz(6)
  status                AppointmentStatus @default(PENDING)
  adminNotes            String?           @map("admin_notes")
  estimatedCost         Decimal?          @map("estimated_cost") @db.Decimal(12, 2)
  finalCost             Decimal?          @map("final_cost") @db.Decimal(12, 2)
  inspectedAt           DateTime?         @map("inspected_at") @db.Timestamptz(6)
  repairedAt            DateTime?         @map("repaired_at") @db.Timestamptz(6)
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer    User        @relation("CustomerAppointments", fields: [customerId], references: [id], onDelete: Cascade)
  serviceBike ServiceBike @relation(fields: [serviceBikeId], references: [id], onDelete: Restrict)

  reviews Review[] @relation("AppointmentReviews")

  @@index([status])
  @@index([customerId, status])
  @@index([serviceBikeId])
  @@index([preferredDate])
  @@map("appointments")
}

// ─── MARKETPLACE LISTINGS ────────────────────────────────────────────────────

model BikeForSale {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId            String        @map("seller_id") @db.Uuid
  brandId             String        @map("brand_id") @db.Uuid
  model               String
  year                Int
  engineType          EngineType    @map("engine_type")
  mileageKm           Int           @map("mileage_km")
  fuelConsumption     Decimal?      @map("fuel_consumption") @db.Decimal(6, 2)
  price               Decimal       @db.Decimal(12, 2)
  currency            String        @default("LKR")
  description         String
  location            String
  photos              String[]      @default([])
  whatsappNumber      String?       @map("whatsapp_number")
  phoneNumber         String?       @map("phone_number")
  status              ListingStatus @default(AVAILABLE)
  isMechanicVerified  Boolean       @default(false) @map("is_mechanic_verified")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  seller       User                  @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  brand        Brand                 @relation(fields: [brandId], references: [id], onDelete: Restrict)
  verification MechanicVerification?

  @@index([status])
  @@index([brandId, price])
  @@index([sellerId])
  @@index([isMechanicVerified])
  @@index([createdAt])
  @@map("bikes_for_sale")
}

// ─── MECHANIC VERIFICATIONS (1:1 with listing — DB trigger flips badge) ──────

model MechanicVerification {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId       String   @unique @map("listing_id") @db.Uuid
  verifiedByAdmin String   @map("verified_by_admin_id") @db.Uuid
  inspectionNotes String   @map("inspection_notes")
  verifiedAt      DateTime @default(now()) @map("verified_at") @db.Timestamptz(6)

  listing BikeForSale @relation(fields: [listingId], references: [id], onDelete: Cascade)
  admin   User        @relation("AdminVerifications", fields: [verifiedByAdmin], references: [id], onDelete: Restrict)

  @@index([verifiedByAdmin])
  @@map("mechanic_verifications")
}

// ─── SHOPS (multi-vendor) ────────────────────────────────────────────────────

model Shop {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId       String     @unique @map("owner_user_id") @db.Uuid
  name              String     @unique
  slug              String     @unique
  description       String?
  logoUrl           String?    @map("logo_url")
  contactEmail      String     @map("contact_email")
  contactPhone      String     @map("contact_phone")
  address           String?
  status            ShopStatus @default(PENDING)
  commissionRate    Decimal    @default(10.00) @map("commission_rate") @db.Decimal(5, 2)
  approvedAt        DateTime?  @map("approved_at") @db.Timestamptz(6)
  approvedByAdminId String?    @map("approved_by_admin_id") @db.Uuid
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner       User        @relation("ShopOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  approvedBy  User?       @relation("AdminApprovedShops", fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  parts       SparePart[]
  orderItems  OrderItem[]

  @@index([status])
  @@map("shops")
}

// ─── PART CATEGORIES ─────────────────────────────────────────────────────────

model PartCategory {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String @unique
  slug  String @unique

  parts SparePart[]

  @@map("part_categories")
}

// ─── SPARE PARTS ─────────────────────────────────────────────────────────────

model SparePart {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId          String   @map("shop_id") @db.Uuid
  brandId         String?  @map("brand_id") @db.Uuid
  categoryId      String   @map("category_id") @db.Uuid
  name            String
  description     String?
  compatibleBikes String[] @default([]) @map("compatible_bikes")
  price           Decimal  @db.Decimal(12, 2)
  currency        String   @default("LKR")
  stockQuantity   Int      @default(0) @map("stock_quantity")
  photos          String[] @default([])
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop       Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  brand      Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category   PartCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]
  reviews    Review[]      @relation("PartReviews")

  @@index([shopId, isActive])
  @@index([brandId])
  @@index([categoryId])
  @@index([isActive, price])
  @@map("spare_parts")
}

// ─── ORDERS ──────────────────────────────────────────────────────────────────

model Order {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId            String      @map("customer_id") @db.Uuid
  status                OrderStatus @default(PENDING)
  subtotal              Decimal     @db.Decimal(12, 2)
  total                 Decimal     @db.Decimal(12, 2)
  currency              String      @default("LKR")
  paymentReference      String?     @unique @map("payment_reference")
  shippingAddress       Json?       @map("shipping_address")
  placedAt              DateTime    @default(now()) @map("placed_at") @db.Timestamptz(6)
  paidAt                DateTime?   @map("paid_at") @db.Timestamptz(6)
  refundedAt            DateTime?   @map("refunded_at") @db.Timestamptz(6)
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer User        @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  items    OrderItem[]

  @@index([customerId, createdAt])
  @@index([status])
  @@map("orders")
}

// ─── ORDER ITEMS (commission locked at sale time) ────────────────────────────

model OrderItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String   @map("order_id") @db.Uuid
  partId           String   @map("part_id") @db.Uuid
  shopId           String   @map("shop_id") @db.Uuid
  quantity         Int
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  commissionRate   Decimal  @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(12, 2)
  lineTotal        Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  SparePart @relation(fields: [partId], references: [id], onDelete: Restrict)
  shop  Shop      @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([shopId, createdAt])
  @@map("order_items")
}

// ─── REVIEWS (XOR target enforced via SQL CHECK constraint in migration) ─────

model Review {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId      String           @map("author_id") @db.Uuid
  rating        Int
  comment       String?
  targetType    ReviewTargetType @map("target_type")
  appointmentId String?          @map("appointment_id") @db.Uuid
  partId        String?          @map("part_id") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  author      User         @relation("AuthorReviews", fields: [authorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation("AppointmentReviews", fields: [appointmentId], references: [id], onDelete: Cascade)
  part        SparePart?   @relation("PartReviews", fields: [partId], references: [id], onDelete: Cascade)

  // One review per (author, appointment) and per (author, part)
  @@unique([authorId, appointmentId], name: "uniq_author_appointment_review")
  @@unique([authorId, partId], name: "uniq_author_part_review")
  @@index([appointmentId])
  @@index([partId])
  @@index([rating])
  @@map("reviews")
}
